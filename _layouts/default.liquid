<!doctype html>
<html lang="{{ site.lang }}">
  <!-- Head -->
  <head>
    {% if page.redirect %}
      {% if page.redirect == true %}
        {% assign redirect = site.baseurl | append: '/' %}
      {% elsif page.redirect contains '://' %}
        {% assign redirect = page.redirect %}
      {% else %}
        {% assign redirect = page.redirect | relative_url %}
      {% endif %}
      <meta http-equiv="refresh" content="3; url={{ redirect }}">
    {% endif %}
    {% include head.liquid %}
  </head>

  <!-- Body -->
  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
    <script>
      document.body.classList.add("has-page-loader");
      window.setTimeout(function () {
        document.body.classList.remove("has-page-loader");
        var staleLoader = document.getElementById("ryk-loader");
        if (staleLoader) {
          staleLoader.classList.add("is-hidden");
          window.setTimeout(function () {
            staleLoader.remove();
          }, 450);
        }
      }, 3200);
    </script>

    <style id="ryk-loader-critical">
      body.has-page-loader {
        overflow: hidden;
      }

      .ryk-loader {
        position: fixed;
        inset: 0;
        z-index: 2500;
        display: grid;
        place-items: center;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        background: radial-gradient(circle at 50% 35%, rgba(59, 130, 246, 0.16), rgba(6, 10, 21, 0.94) 52%, rgba(2, 6, 23, 0.98));
        transition: opacity 0.35s ease, visibility 0.35s ease;
        -webkit-backdrop-filter: blur(4px);
        backdrop-filter: blur(4px);
      }

      body.has-page-loader .ryk-loader {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
      }

      .ryk-loader.is-hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .ryk-loader__inner {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.95rem;
      }

      .ryk-loader__halo {
        position: absolute;
        top: 52%;
        width: 180px;
        height: 180px;
        transform: translateY(-50%);
        border-radius: 50%;
        background: radial-gradient(circle, rgba(37, 99, 235, 0.24) 0%, rgba(37, 99, 235, 0.08) 42%, rgba(37, 99, 235, 0) 72%);
        filter: blur(6px);
        pointer-events: none;
      }

      .ryk-loader__orbital {
        position: relative;
        width: 116px;
        height: 116px;
        display: grid;
        place-items: center;
      }

      .ryk-loader__ring {
        position: absolute;
        border-radius: 999px;
        border: 2px solid transparent;
      }

      .ryk-loader__ring--outer {
        inset: 0;
        border-top-color: #60a5fa;
        border-right-color: #2563eb;
        box-shadow: 0 0 24px rgba(37, 99, 235, 0.25);
        animation: ryk-spin 1.1s linear infinite;
      }

      .ryk-loader__ring--inner {
        inset: 16px;
        border-bottom-color: #93c5fd;
        border-left-color: #3b82f6;
        animation: ryk-spin-reverse 0.8s linear infinite;
      }

      .ryk-loader__core {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        border: 1px solid rgba(29, 78, 216, 0.25);
        background: linear-gradient(145deg, #eff6ff, #dbeafe);
        color: #1e3a8a;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-transform: uppercase;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.2), inset 0 0 12px rgba(255, 255, 255, 0.35);
      }

      .ryk-loader__text {
        margin: 0;
        color: #cbd5e1;
        font-size: 0.76rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      html[data-theme='dark'] .ryk-loader__core {
        background: linear-gradient(145deg, #0b1220, #0f172a);
        border-color: rgba(147, 197, 253, 0.35);
        color: #bfdbfe;
        box-shadow: 0 10px 30px rgba(2, 6, 23, 0.55), inset 0 0 12px rgba(96, 165, 250, 0.16);
      }

      @keyframes ryk-spin {
        from {
          transform: rotate(0deg);
        }

        to {
          transform: rotate(360deg);
        }
      }

      @keyframes ryk-spin-reverse {
        from {
          transform: rotate(360deg);
        }

        to {
          transform: rotate(0deg);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .ryk-loader,
        .ryk-loader * {
          animation: none !important;
          transition: none !important;
        }
      }
    </style>

    <div id="ryk-loader" class="ryk-loader" aria-hidden="true">
      <div class="ryk-loader__inner">
        <span class="ryk-loader__halo" aria-hidden="true"></span>
        <div class="ryk-loader__orbital">
          <span class="ryk-loader__ring ryk-loader__ring--outer"></span>
          <span class="ryk-loader__ring ryk-loader__ring--inner"></span>
          <span class="ryk-loader__core">RYK</span>
        </div>
        <p class="ryk-loader__text">Loading Ryan Kim</p>
      </div>
    </div>

    <!-- Header -->
    {% include header.liquid %}

    <!-- Content -->
    <div class="container mt-5" role="main">
      {% if page.toc and page.toc.sidebar %}
        {% if page.toc.sidebar == 'right' %}
          <div class="row">
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
          </div>
        {% else %}
          <div class="row">
            <!-- sidebar, which will move to the top on a small screen -->
            <div class="col-sm-3">
              <nav id="toc-sidebar" class="sticky-top"></nav>
            </div>
            <!-- main content area -->
            <div class="col-sm-9">{{ content }}</div>
          </div>
        {% endif %}
      {% else %}
        {{ content }}
      {% endif %}
    </div>

    <!-- Footer -->
    {% comment %}{% include footer.liquid %}{% endcomment %}

    <!-- JavaScripts -->
    {% include scripts.liquid %}
  </body>
</html>
